---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.pubDate?.valueOf() || 0;
  const dateB = b.data.pubDate?.valueOf() || 0;
  return dateB - dateA;
});
const latestPostsEs = sortedPosts.filter(p => (p.data.lang || 'es') === 'es').slice(0, 3);
const latestPostsEn = sortedPosts.filter(p => p.data.lang === 'en').slice(0, 3);
---

<Layout
  title="DEVFHM | Desarrollador UX/UI & Experiencias Web Disruptivas"
  description="Portfolio de talento digital especializado en interfaces interactivas, Arquitectura Frontend, Bento UI y diseños premium de alto impacto. Código con alma disruptiva."
>
  <Navbar />
  <!-- Hero Section -->
  <section id="inicio" class="pt-32 pb-16 px-6 overflow-hidden relative dark:bg-black">
    <!-- Animated Gradient & Blob Background -->
    <div
      class="absolute inset-0 overflow-hidden pointer-events-none z-0 bg-background dark:bg-black"
    >
      <div
        class="absolute inset-0 opacity-20 animate-pulse transition-opacity duration-1000"
        style="
            background-image: radial-gradient(var(--hero-dots) 1px, transparent 1px);
            background-size: 30px 30px;
          "
      >
      </div>
      <div
        class="absolute top-[5%] left-[10%] w-[60vw] h-[60vw] max-w-[500px] max-h-[500px] bg-primary rounded-full mix-blend-multiply filter blur-[100px] opacity-30"
        style="animation: blob 8s infinite alternate ease-in-out"
      >
      </div>
      <div
        class="absolute top-[20%] right-[5%] w-[50vw] h-[50vw] max-w-[400px] max-h-[400px] bg-[#C1FF00] rounded-full mix-blend-multiply filter blur-[100px] opacity-14"
        style="
            animation: blob 10s infinite alternate-reverse ease-in-out;
            animation-delay: 2s;
          "
      >
      </div>
      <div
        class="absolute -bottom-[10%] left-[30%] w-[70vw] h-[70vw] max-w-[600px] max-h-[600px] bg-[#2D5BFF] rounded-full mix-blend-multiply filter blur-[120px] opacity-12"
        style="
            animation: blob 12s infinite alternate ease-in-out;
            animation-delay: 4s;
          "
      >
      </div>
    </div>
    <style>
      @keyframes blob {
        0% {
          transform: translate(0px, 0px) scale(1);
        }
        33% {
          transform: translate(30px, -50px) scale(1.1);
        }
        66% {
          transform: translate(-20px, 20px) scale(0.9);
        }
        100% {
          transform: translate(0px, 0px) scale(1);
        }
      }
      .hero-title span {
        position: relative;
        z-index: 20;
      }
      .text-outline-digital {
        position: relative;
        z-index: 10;
        -webkit-text-stroke: 2px #0040df;
        color: transparent;
      }
      /* Nav Link Hover Effect */
      .nav-link {
        position: relative;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        color: #434656;
        font-family: "Epilogue", sans-serif;
        letter-spacing: -0.02em;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        width: 0;
        height: 3px;
        bottom: -8px;
        left: 50%;
        background: linear-gradient(90deg, #0040df, #2d5bff);
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        transform: translateX(-50%);
        border-radius: 99px;
      }
      .nav-link:hover {
        transform: translateY(-2px) scale(1.05);
        color: #0040df !important;
      }
      .nav-link:hover::after {
        width: 100%;
      }
      .nav-link-active {
        color: #0040df !important;
      }
      .nav-link-active::after {
        width: 80%;
      }

      /* Tech Carousel (Logo Marquee) - Refined Design */
      .marquee-container {
        padding: 6rem 0;
        padding: 8rem 0;
        background: #f9f9f9;
        position: relative;
        text-align: center;
        overflow: hidden;
        perspective: 1000px; /* For 3D depth */
      }
      :global(.dark) .marquee-container {
        background: #000000;
      }
      .marquee-viewport {
        max-width: 880px;
        margin: 0 auto;
        position: relative;
        overflow: hidden;
      }
      /* Extra-wide fades for the narrow 880px viewport */
      .marquee-viewport::before,
      .marquee-viewport::after {
        content: "";
        position: absolute;
        top: 0;
        width: 250px;
        height: 100%;
        z-index: 20;
        pointer-events: none;
      }
      .marquee-viewport::before {
        left: 0;
        background: linear-gradient(to right, #f9f9f9 40%, transparent);
      }
      :global(.dark) .marquee-viewport::before {
        background: linear-gradient(to right, #000000 40%, transparent);
      }
      .marquee-viewport::after {
        right: 0;
        background: linear-gradient(to left, #f9f9f9 40%, transparent);
      }
      :global(.dark) .marquee-viewport::after {
        background: linear-gradient(to left, #000000 40%, transparent);
      }
      .marquee-header {
        max-width: 600px;
        margin: 0 auto 4rem;
      }
      .marquee-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 16px;
        border: 1px solid #e2e2e2;
        border-radius: 99px;
        background: white;
        color: #747688;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        font-family: "Epilogue", sans-serif;
      }
      :global(.dark) .marquee-badge {
        background: #1a1a1a;
        border-color: #434656;
        color: #c4c5d9;
      }
      .marquee-title {
        margin-bottom: 2rem;
      }
      .marquee-subtitle {
        color: #747688;
        line-height: 1.6;
        font-size: 1.1rem;
      }
      .marquee-content {
        display: flex;
        gap: 100px;
        width: max-content;
        animation: scroll 35s linear infinite;
        padding: 25px 0;
      }
      .marquee-item {
        width: 150px;
        height: 150px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
      }
      :global(.dark) .marquee-item {
        background: #1a1a1a;
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.05);
      }
      .marquee-item i {
        font-size: 5rem;
        transition: transform 0.4s ease;
      }
      .marquee-item:hover {
        transform: scale(1.05) translateY(-5px);
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.15);
        z-index: 50;
      }
      :global(.dark) .marquee-item:hover {
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.3);
      }
      /* Offset animations for organic look */
      .marquee-item:nth-child(even) {
        animation-delay: -2s;
      }
      .marquee-item:nth-child(3n) {
        animation-delay: -1s;
      }
      @keyframes scroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      @keyframes scroll-reverse {
        0% {
          transform: translateX(-50%);
        }
        100% {
          transform: translateX(0);
        }
      }
      .marquee-content-reverse {
        animation: scroll-reverse 35s linear infinite;
      }
      .marquee-row {
        display: flex;
        flex-direction: column;
        gap: 0px;
      }
    </style>

