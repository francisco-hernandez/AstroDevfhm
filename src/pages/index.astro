  <script is:inline>
    // Hero Animations
    gsap.from(".hero-badge", {
      opacity: 0,
      y: -20,
      duration: 1,
      ease: "power3.out",
    });
    gsap.from(".hero-title", {
      opacity: 0,
      x: -50,
      duration: 1.2,
      delay: 0.2,
      ease: "power4.out",
    });
    gsap.from(".hero-p", {
      opacity: 0,
      y: 20,
      duration: 1,
      delay: 0.5,
      ease: "power2.out",
    });
    gsap.from(".hero-btns", {
      opacity: 0,
      y: 30,
      duration: 0.8,
      delay: 0.8,
      ease: "back.out(1.7)",
    });
    gsap.from(".hero-image", {
      opacity: 0,
      scale: 0.8,
      duration: 1.5,
      delay: 0.2,
      ease: "expo.out",
    });

    // Subtle Mouse Parallax Effect
    document.addEventListener("mousemove", (e) => {
      const mouseX = (e.clientX / window.innerWidth - 0.5) * 15;
      const mouseY = (e.clientY / window.innerHeight - 0.5) * 15;

      gsap.to(".hero-image", {
        x: mouseX,
        y: mouseY,
        duration: 1.5,
        ease: "power2.out",
      });

      gsap.to(".floating-icon", {
        x: (i) => mouseX * (1.2 + i * 0.05),
        y: (i) => mouseY * (1.2 + i * 0.05),
        duration: 2,
        ease: "power2.out",
        overwrite: "auto",
      });
    });
  </script>
