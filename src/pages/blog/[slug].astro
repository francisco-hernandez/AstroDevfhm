---
import { getCollection, render } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, description, category, pubDate, author, image, authorRole, readTime } = entry.data;
const lang = entry.data.lang || 'es';
const translationSlug = entry.data.translationSlug || null;

// i18n system texts for the article page
const ui = {
  es: {
    trending: 'Tendencias',
    relatedTitle: 'Artículos Relacionados',
    relatedDesc: 'Continúa explorando el ecosistema disruptor.',
    viewAll: 'Ver todos',
    exploreMore: 'Explora más artículos en nuestro blog.',
    copyright: '© 2026 DEVFHM. Todos los derechos reservados.',
    designed: 'Diseñado por y para la web',
  },
  en: {
    trending: 'Trending',
    relatedTitle: 'Related Articles',
    relatedDesc: 'Keep exploring the disruptive ecosystem.',
    viewAll: 'View all',
    exploreMore: 'Explore more articles on our blog.',
    copyright: '© 2026 DEVFHM. All rights reserved.',
    designed: 'Designed by and for the web',
  },
} as const;

const t = ui[lang as keyof typeof ui] ?? ui['es'];

// Format date locale
const dateLocale = lang === 'en' ? 'en-US' : 'es-ES';
const formattedDate = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate).toUpperCase();
---

<Layout title={`${title} | Blog DEVFHM`} description={description} bodyAttrs={{ 'data-article-lang': lang, 'data-translation-slug': translationSlug ?? '' }}>
    
    <Navbar />

    <main class="pt-40 md:pt-48 pb-20">
      <!-- Hero Section -->
      <header class="relative max-w-7xl mx-auto px-8 mb-16 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-8 z-10 relative">
            <div
              class="mb-6 inline-flex items-center space-x-2 bg-secondary-container text-on-secondary-container px-4 py-1 rounded-full"
            >
              <span
                class="text-[0.7rem] font-black font-headline tracking-widest uppercase"
                >{category} / BLOG</span
              >
            </div>
            <h1
              class="font-headline text-5xl md:text-7xl lg:text-8xl font-black leading-[0.9] tracking-tighter mb-8 text-on-background"
            >
              {title}
            </h1>
            <div class="flex items-center space-x-4 mb-8">
              <div
                class="w-12 h-12 rounded-full bg-surface-container overflow-hidden"
              >
                <img
                  alt="Author"
                  class="w-full h-full object-cover"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuC54hd-g-2cFLoU8oHYtk-J2drA_041s0OAOVBb7lYJeKE8VAGay-QyH-WozpqGMqZ5aJrBRNVL3Tq7iUN2sbIEl-H5QnNgX6J7YWzpoGFknb0CqKqb-6uts1U_Zmw5XPA3vncQUE0rT5aXEXMcRclMs9yWTvh_kwDRddKEohdd2kdFH6oiG-KEs790KgKc0FYY9XePhTaUJhfMPcIQ6z9mm5tTZ5GYAT9xnrj4K6uTtaAM_fpAHmKPoIQhzCWOzIaTVUqTxlW48e16"
                />
              </div>
              <div>
                <p class="font-headline font-bold text-lg leading-tight">
                  {author}
                </p>
                <p class="text-outline text-sm">
                  {authorRole}
                </p>
              </div>
              <div class="h-8 w-[1px] bg-outline-variant/30 mx-2"></div>
              <p class="text-outline text-sm font-medium tracking-wide">
                {formattedDate} — {readTime}
              </p>
            </div>
          </div>
        </div>
        <div
          class="relative w-full aspect-[21/9] rounded-3xl overflow-hidden mt-8 shadow-2xl"
        >
          <img
            alt={title}
            class="w-full h-full object-cover"
            src={image}
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"
          ></div>
        </div>
      </header>
      <!-- Article Content -->
      <section
        class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-16"
      >
        <!-- Side Metadata/Social (Sticky) -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-32 flex flex-col items-center space-y-8">
            <span
              class="material-symbols-outlined text-outline hover:text-primary cursor-pointer transition-colors"
              style="font-variation-settings: &quot;FILL&quot; 0"
              >favorite</span
            >
            <span
              class="material-symbols-outlined text-outline hover:text-primary cursor-pointer transition-colors"
              >share</span
            >
            <span
              class="material-symbols-outlined text-outline hover:text-primary cursor-pointer transition-colors"
              >bookmark</span
            >
            <div class="h-12 w-[1px] bg-outline-variant/30"></div>
            <span
              class="font-headline font-black text-xs vertical-rl tracking-widest text-outline"
              >SCROLL</span
            >
          </div>
        </aside>
        <!-- Main Reading Area -->
        <article class="lg:col-span-8 space-y-12">
          <div
            class="prose prose-xl prose-slate max-w-none font-body text-on-surface-variant leading-relaxed dark:prose-invert"
          >
            <Content />
          </div>
          <!-- Interaction Tags -->
          <div class="pt-12 border-t border-outline-variant/20">
            <div class="flex flex-wrap gap-3">
              <span
                class="px-5 py-2 rounded-full bg-surface-container-lowest border border-outline-variant/30 text-xs font-headline font-bold text-primary hover:bg-primary hover:text-white transition-all cursor-pointer"
                >DESIGN SYSTEM</span
              >
              <span
                class="px-5 py-2 rounded-full bg-surface-container-lowest border border-outline-variant/30 text-xs font-headline font-bold text-primary hover:bg-primary hover:text-white transition-all cursor-pointer"
                >ARCHITECTURE</span
              >
              <span
                class="px-5 py-2 rounded-full bg-surface-container-lowest border border-outline-variant/30 text-xs font-headline font-bold text-primary hover:bg-primary hover:text-white transition-all cursor-pointer"
                >MINIMALISM</span
              >
              <span
                class="px-5 py-2 rounded-full bg-surface-container-lowest border border-outline-variant/30 text-xs font-headline font-bold text-primary hover:bg-primary hover:text-white transition-all cursor-pointer"
                >DEVELOPMENT</span
              >
            </div>
          </div>
        </article>
        <!-- Sidebar Info / Newsletter -->
        <aside class="lg:col-span-3 space-y-12">
          <div class="space-y-6">
            <h4
              class="font-headline font-bold text-lg border-l-4 border-secondary px-4"
            >
              {t.trending}
            </h4>
            <div class="space-y-6">
              <div class="group cursor-pointer">
                <span class="text-xs font-black text-primary/50 block mb-1"
                  >01 / CONCEPT</span
                >
                <h5
                  class="font-headline font-bold leading-tight group-hover:text-primary transition-colors"
                >
                  {lang === 'en' ? 'Micro-interactions in VR: The future of visual touch' : 'Micro-interacciones en VR: El futuro del tacto visual'}
                </h5>
              </div>
              <div class="group cursor-pointer">
                <span class="text-xs font-black text-primary/50 block mb-1"
                  >02 / DEV</span
                >
                <h5
                  class="font-headline font-bold leading-tight group-hover:text-primary transition-colors"
                >
                  {lang === 'en' ? 'Why Tailwind CSS is the end of giant stylesheets' : 'Por qué Tailwind CSS es el fin de las hojas de estilo gigantes'}
                </h5>
              </div>
            </div>
          </div>
        </aside>
      </section>
      
      <!-- Related Articles Grid (Simplified for dynamic route) -->
      <section class="max-w-7xl mx-auto px-8 mt-32">
        <div class="flex justify-between items-end mb-12">
          <div>
            <h2 class="font-headline text-4xl font-black tracking-tighter">
              {t.relatedTitle}
            </h2>
            <p class="text-outline mt-2">
              {t.relatedDesc}
            </p>
          </div>
          <a
            class="hidden md:flex items-center space-x-2 text-primary font-bold hover:translate-x-2 transition-transform"
            href="/blog"
          >
            <span>{t.viewAll}</span>
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
           <!-- Potential related posts would go here -->
           <p class="text-on-surface-variant italic">{t.exploreMore}</p>
        </div>
      </section>
    </main>
    
    <Footer />
</Layout>

<script is:inline>
  // Hero Animations (simplified for dynamic route)
  if (typeof gsap !== 'undefined') {
    gsap.from("h1", { opacity: 0, y: 30, duration: 1, ease: "power3.out" });
    gsap.from("header img", { opacity: 0, scale: 1.1, duration: 1.5, ease: "expo.out" });
  }
</script>
