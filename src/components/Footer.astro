  >
    <div class="flex flex-wrap justify-center gap-12">
      <a
        class="text-on-surface-variant dark:text-white font-['Epilogue'] uppercase tracking-widest font-bold hover:text-primary transition-colors"
        href="#"
        data-key="footer.github">Github</a
