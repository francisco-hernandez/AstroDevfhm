<section id="proyectos" class="section-padding bg-surface-container-low dark:bg-slate-900/30 rounded-[3.5rem] my-32">
	<div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
		<div>
			<h2 class="text-5xl md:text-6xl font-black mb-4">Portfolio <span class="text-primary italic">Dinámico</span></h2>
			<p class="text-on-surface-variant text-xl">Una selección de visiones convertidas en realidad digital.</p>
		</div>
		<a href="#" class="text-primary font-headline font-black flex items-center gap-2 group hover:gap-4 transition-all uppercase tracking-widest text-sm">
			Explorar todo el archivo <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
		</a>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
		{projects.map((project) => (
			<div class={`group cursor-pointer ${project.class}`}>
				<div class="overflow-hidden rounded-[2.5rem] bg-white dark:bg-slate-800 aspect-video mb-8 shadow-ambient relative">
					<img 
						src={project.image} 
						alt={project.title} 
						class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
					/>
					<div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
						<span class="btn-primary py-3 px-8 text-sm">Ver Detalle</span>
					</div>
				</div>
				<div class="flex justify-between items-start px-4">
					<div>
						<h3 class="font-headline font-black text-3xl mb-1">{project.title}</h3>
						<p class="text-on-surface-variant font-medium text-lg uppercase tracking-tight opacity-70">{project.category}</p>
					</div>
					<span class="bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-dim px-5 py-2 rounded-full text-xs font-black">
						{project.year}
					</span>
				</div>
			</div>
		))}
	</div>
</section>
