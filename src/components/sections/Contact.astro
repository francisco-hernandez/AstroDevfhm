---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="relative overflow-hidden bg-primary text-white py-32 md:py-48 rounded-t-[4rem] -mt-12">
	<!-- Floating Sticker Elements -->
	<div class="absolute top-20 right-10 rotate-12 bg-secondary-container text-on-surface px-8 py-3 rounded-full font-black text-sm shadow-premium z-10 hidden lg:block uppercase tracking-widest">
		¡Hablemos de verdad!
	</div>
	<div class="absolute bottom-40 left-10 -rotate-6 bg-tertiary-container text-white px-8 py-3 rounded-full font-black text-sm shadow-premium z-10 hidden lg:block uppercase tracking-widest">
		Código con Alma
	</div>

	<div class="max-w-6xl mx-auto px-8 relative z-0">
		<div class="flex flex-col lg:flex-row gap-24 items-center">
			<div class="lg:w-1/2">
				<h2 class="text-7xl md:text-9xl font-black leading-[0.85] mb-12 tracking-tighter">
					¿Creamos algo <span class="italic text-secondary-container">legendario</span>?
				</h2>
				<p class="text-2xl md:text-3xl opacity-80 mb-16 font-light leading-relaxed max-w-lg">
					Olvida los formularios aburridos. Cuéntame tu visión como si estuviéramos tomando un café.
				</p>
				
				<div class="space-y-8">
					<div class="flex items-center gap-6 text-2xl font-black group cursor-pointer hover:text-secondary-container transition-colors">
						<span class="material-symbols-outlined text-4xl">alternate_email</span>
						<span>hola@devfhm.com</span>
					</div>
					<div class="flex items-center gap-6 text-2xl font-black group cursor-pointer hover:text-secondary-container transition-colors">
						<span class="material-symbols-outlined text-4xl">chat_bubble</span>
						<span>@elperezoso_dev</span>
					</div>
				</div>
			</div>

			<div class="lg:w-1/2 w-full">
				<form 
					name="contact" 
					method="POST" 
					data-netlify="true" 
					class="bg-white text-on-surface p-12 md:p-16 rounded-[4rem] shadow-premium transform rotate-1 hover:rotate-0 transition-transform duration-500"
				>
					<div class="space-y-12">
						<div class="relative group">
							<p class="text-xl font-headline font-black mb-4 uppercase tracking-widest text-primary/40 group-focus-within:text-primary transition-colors">
								"Hola, mi nombre es..."
							</p>
							<input 
								type="text" 
								name="name" 
								required 
								placeholder="Tu nombre aquí" 
								class="w-full border-b-[3px] border-surface-container-high focus:border-primary bg-transparent py-4 text-3xl font-headline font-black outline-none transition-all placeholder:text-surface-container-high"
							/>
						</div>

						<div class="relative group">
							<p class="text-xl font-headline font-black mb-4 uppercase tracking-widest text-primary/40 group-focus-within:text-primary transition-colors">
								"Puedes contactarme en..."
							</p>
							<input 
								type="email" 
								name="email" 
								required 
								placeholder="Tu email favorito" 
								class="w-full border-b-[3px] border-surface-container-high focus:border-primary bg-transparent py-4 text-3xl font-headline font-black outline-none transition-all placeholder:text-surface-container-high"
							/>
						</div>

						<div class="relative group">
							<p class="text-xl font-headline font-black mb-4 uppercase tracking-widest text-primary/40 group-focus-within:text-primary transition-colors">
								"Tengo una idea sobre..."
							</p>
							<textarea 
								name="message" 
								required 
								rows="2" 
								placeholder="Cuéntame tu sueño..." 
								class="w-full border-b-[3px] border-surface-container-high focus:border-primary bg-transparent py-4 text-3xl font-headline font-black outline-none transition-all resize-none placeholder:text-surface-container-high"
							></textarea>
						</div>

						<button 
							type="submit" 
							class="w-full bg-secondary-container text-on-surface py-8 rounded-[2rem] font-headline font-black text-2xl shadow-premium hover:scale-[1.05] hover:bg-secondary-fixed transition-all active:scale-95 uppercase tracking-widest"
						>
							¡Enviar mi Visión! 🚀
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>
