---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
	{
		title: 'UI/UX Boutique',
		description: 'Interfaces curadas con atención obsesiva al detalle. No diseñamos pantallas, creamos experiencias táctiles digitales.',
		icon: 'draw',
		class: 'md:col-span-8 bg-surface-container-low dark:bg-surface-container-high',
		tags: ['Figma', 'Prototyping'],
		iconClass: 'text-primary'
	},
	{
		title: 'Consultoría Estratégica',
		description: 'Arquitectura de producto y escalabilidad tecnológica desde el día uno.',
		icon: 'lightbulb',
		class: 'md:col-span-4 bg-secondary-container text-on-surface',
		iconClass: 'text-on-surface'
	},
	{
		title: 'Web Apps Modernas',
		description: 'React, Next.js y Astro para una velocidad sin compromisos.',
		icon: 'terminal',
		class: 'md:col-span-5 bg-surface-container-highest dark:bg-surface-container-highest',
		iconClass: 'text-primary'
	},
	{
		title: 'Core Web Vitals',
		description: 'Optimización extrema de rendimiento. Puntuaciones de 100 en Lighthouse como estándar.',
		icon: 'speed',
		class: 'md:col-span-7 bg-primary text-white',
		iconClass: 'text-secondary-container'
	}
];
---

<section id="servicios" class="section-padding mt-12 mb-12">
	<div class="mb-20">
		<h2 class="text-5xl md:text-6xl font-black mb-4">
			Servicios <span class="text-secondary dark:text-secondary-container">Premium</span>
		</h2>
		<p class="text-on-surface-variant text-xl">Especialización boutique para productos digitales que destacan.</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:min-h-[600px]">
		{services.map((service, index) => (
			<div 
				class={`rounded-[2.5rem] p-10 flex flex-col justify-between group cursor-pointer transition-all hover:scale-[1.02] shadow-ambient ${service.class}`}
			>
				<div class="flex justify-between items-start">
					<span class={`material-symbols-outlined text-5xl ${service.iconClass}`}>
						{service.icon}
					</span>
					{index === 2 && <span class="text-primary font-black text-4xl opacity-10">01</span>}
					{index === 3 && (
						<div class="w-16 h-16 rounded-full border-4 border-secondary-container border-t-transparent animate-spin"></div>
					)}
				</div>

				<div class="mt-8">
					<h3 class={`text-3xl font-black mb-4 leading-tight`}>
						{service.title}
					</h3>
					<p class="text-lg opacity-80 leading-relaxed max-w-md">
						{service.description}
					</p>
					
					{service.tags && (
						<div class="mt-8 flex gap-3">
							{service.tags.map(tag => (
								<span class="bg-surface/30 dark:bg-white/10 px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">
									{tag}
								</span>
							))}
						</div>
					)}
				</div>
			</div>
		))}
	</div>
</section>
