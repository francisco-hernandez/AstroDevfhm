---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const slothWorkingImg = "https://lh3.googleusercontent.com/aida-public/AB6AXuA5cgozfrjDgyH2WlhcQUWBhRDVXh5LDSxDz8jqXnqsvTaJV7A9P6O12HS8ag6EYJwvN751R8VqaqtSeXXiEh7xQRjHBqzl61UVGPgYK10flS32WyV141TId0SBNWIGAeYV4ChMfhVPUWRHbkA1EMATyLOE8fUJvHrKeLE727d1-fBpmJq39Ug5J-3zl6TZaYvFzFjIWZeBZnZU27eBnvGNFKZov3Pe05ew5jmny2J37V2-3JdcsHmtSQEJSIVPaIfimnyDjsunUY14";
---

<section id="sobre-mi" class="section-padding overflow-visible">
	<div class="relative bg-secondary-container dark:bg-secondary/20 rounded-[3.5rem] p-12 lg:p-24 shadow-premium">
		<!-- Signature background elements -->
		<div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
			<div class="relative z-10">
				<h2 class="text-5xl md:text-7xl font-black mb-10 leading-[0.9] text-on-surface dark:text-white">
					El Perezoso Desarrollador <br/>
					<span class="text-primary/40 dark:text-primary-dim/30 italic">no es un</span> <br/>
					Desarrollador Perezoso.
				</h2>
				
				<div class="space-y-6 text-xl md:text-2xl text-on-surface dark:text-on-surface/90 leading-relaxed font-medium">
					<p>
						En un mundo que corre sin mirar atrás, yo elijo la calma estratégica. Mi alias es una oda a la eficiencia: hacer las cosas tan bien a la primera, que no haya que trabajar dos veces.
					</p>
					<p class="opacity-80">
						Curador de código limpio, amante de la tipografía perfecta y firme creyente de que menos es, casi siempre, mucho más.
					</p>
				</div>
			</div>

			<div class="relative lg:-mr-48">
				<div class="bg-white dark:bg-slate-800 p-8 rounded-[2.5rem] shadow-ambient transform lg:rotate-3 hover:rotate-0 transition-all duration-700">
					<div class="aspect-[4/3] rounded-2xl overflow-hidden mb-8">
						<img 
							src={slothWorkingImg} 
							alt="Geeky Sloth Working" 
							class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
						/>
					</div>
					
					<div class="flex items-center gap-6">
						<div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-white shadow-premium">
							<span class="material-symbols-outlined text-3xl">auto_awesome</span>
						</div>
						<div>
							<p class="font-headline font-black text-2xl">Curated Execution</p>
							<p class="text-on-surface-variant dark:text-on-surface-variant font-bold uppercase tracking-widest text-xs mt-1">Quality over Quantity</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
