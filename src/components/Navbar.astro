---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
	{ title: t('nav.inicio'), href: '#inicio', icon: 'home', color: 'primary' },
	{ title: t('nav.servicios'), href: '#servicios', icon: 'handyman', color: 'secondary' },
	{ title: t('nav.sobre-mi'), href: '#sobre-mi', icon: 'person', color: 'tertiary' },
	{ title: t('nav.proyectos'), href: '#proyectos', icon: 'work', color: 'primary' },
	{ title: t('nav.blog'), href: '#blog', icon: 'article', color: 'secondary' },
];
---

<!-- Navbar moderna 2026 con fondo sólido -->
<nav class="fixed top-0 w-full z-[100] bg-surface dark:bg-surface-dark border-b border-outline dark:border-outline-dark shadow-lg">
	<div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
		<!-- Logo con efecto sólido -->
		<a href="/" class="group relative">
			<div class="absolute inset-0 bg-primary rounded-xl blur-lg opacity-0 group-hover:opacity-70 transition-all duration-500"></div>
			<div class="relative text-on-surface dark:text-white text-2xl font-black tracking-tighter font-headline uppercase px-3 py-1">
				DEVFHM
				<span class="absolute -bottom-1 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></span>
			</div>
		</a>

		<!-- Menú Desktop inspirado en móvil -->
		<div class="hidden md:flex items-center gap-4">
			{navItems.map((item, index) => (
				<a
					href={item.href}
					class="desktop-nav-link group relative overflow-hidden rounded-2xl p-4 transition-all duration-500 hover:scale-[1.02]"
					data-index={index}
					data-color={item.color}
				>
					<!-- Background effect -->
					<div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-15 transition-all duration-500" style="background-color: var(--solid-color);"></div>
					
					<!-- Content -->
					<div class="relative z-10 flex items-center gap-3">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:scale-110 group-hover:rotate-6" style="background-color: var(--solid-color);">
							<span class="material-symbols-outlined text-white text-lg">{item.icon}</span>
						</div>
						<div class="flex flex-col">
							<h3 class="text-sm font-black mb-1 transition-all duration-300 relative">
								<span class="nav-text-base text-on-surface dark:text-white">{item.title}</span>
							</h3>
							<div class="h-0.5 w-0 rounded-full transition-all duration-500 group-hover:w-full" style="background-color: var(--solid-color);"></div>
						</div>
					</div>
				</a>
			))}
		</div>

		<!-- Controles modernos -->
		<div class="flex items-center gap-3">
			<!-- Botón hamburguesa futurista -->
			<button 
				id="mobile-menu-toggle" 
				class="md:hidden relative group p-2 rounded-xl bg-primary transition-all duration-300 hover:scale-110 hover:shadow-lg"
				aria-label="Toggle mobile menu"
			>
				<span class="material-symbols-outlined text-white text-xl group-hover:scale-110 transition-transform duration-300">apps</span>
			</button>

			<!-- Selector de idioma moderno -->
			<div class="hidden md:flex items-center gap-2">
				<a
					href={lang === 'es' ? '/en/' : '/'}
					class="relative group px-3 py-1.5 rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-lg hover:bg-surface-container dark:hover:bg-surface-container"
				>
					<span class="relative z-10 text-xs font-black uppercase tracking-wider text-on-surface dark:text-white transition-colors duration-300 group-hover:text-on-surface dark:group-hover:text-on-surface">{lang === 'es' ? 'EN' : 'ES'}</span>
					<div class="absolute inset-0 rounded-lg bg-primary opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
				</a>
			</div>
			
			<!-- Theme toggle modernizado -->
			<div class="hidden md:block">
				<ThemeToggle />
			</div>
			
			<!-- Botón contacto con estilo btn-secondary -->
			<a href="#contacto" class="hidden sm:block btn-secondary">
				{t('nav.contacto')}
			</a>
		</div>
	</div>
</nav>

<!-- Menú móvil simplificado -->
<div id="mobile-menu" class="fixed inset-0 z-[9999] bg-surface dark:bg-surface-dark md:hidden" style="display: none;">
	<div class="flex flex-col h-full p-6">
		<!-- Header -->
		<div class="flex items-center justify-between mb-8">
			<h2 class="text-2xl font-black text-on-surface dark:text-white">Menú</h2>
			<button id="mobile-menu-close" class="p-2 rounded-xl bg-primary text-white">
				<span class="material-symbols-outlined">close</span>
			</button>
		</div>
		
		<!-- Navegación -->
		<nav class="flex-1 overflow-y-auto">
			<div class="flex flex-col gap-3">
				{navItems.map((item) => (
					<a
						href={item.href}
						class="flex items-center gap-4 p-4 rounded-xl bg-surface-container dark:bg-surface-container-high-dark border border-outline/10 dark:border-outline-dark/20 hover:bg-primary/10 transition-colors"
						onclick="document.getElementById('mobile-menu').style.display='none'"
					>
						<div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center flex-shrink-0">
							<span class="material-symbols-outlined text-white text-xl">{item.icon}</span>
						</div>
						<span class="text-lg font-bold text-on-surface dark:text-white">{item.title}</span>
					</a>
				))}
				
				<!-- Selector idioma -->
				<a
					href={lang === 'es' ? '/en/' : '/'}
					class="flex items-center gap-4 p-4 rounded-xl bg-surface-container dark:bg-surface-container-high-dark border border-outline/10 dark:border-outline-dark/20 hover:bg-secondary/20 transition-colors"
				>
					<div class="w-12 h-12 rounded-xl bg-secondary flex items-center justify-center flex-shrink-0">
						<span class="material-symbols-outlined text-white text-xl">language</span>
					</div>
					<span class="text-lg font-bold text-on-surface dark:text-white">{lang === 'es' ? 'English' : 'Español'}</span>
				</a>
				
				<!-- Theme toggle -->
				<button
					id="mobile-theme-btn"
					class="flex items-center gap-4 p-4 rounded-xl bg-surface-container dark:bg-surface-container-high-dark border border-outline/10 dark:border-outline-dark/20 hover:bg-tertiary/20 transition-colors w-full text-left"
				>
					<div class="w-12 h-12 rounded-xl bg-tertiary flex items-center justify-center flex-shrink-0">
						<span id="theme-icon-dark" class="material-symbols-outlined text-white text-xl">dark_mode</span>
						<span id="theme-icon-light" class="material-symbols-outlined text-white text-xl hidden">light_mode</span>
					</div>
					<span id="theme-text-dark" class="text-lg font-bold text-on-surface dark:text-white">Modo Oscuro</span>
					<span id="theme-text-light" class="text-lg font-bold text-on-surface dark:text-white hidden">Modo Claro</span>
				</button>
				
				<!-- Contacto -->
				<a
					href="#contacto"
					class="flex items-center justify-center p-4 rounded-xl bg-primary text-white font-bold text-lg mt-4"
					onclick="document.getElementById('mobile-menu').style.display='none'"
				>
					{t('nav.contacto')}
				</a>
			</div>
		</nav>
	</div>
</div>

<style>
	@keyframes gradient {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}
	
	.animate-gradient {
		background-size: 200% 200%;
		animation: gradient 3s ease infinite;
	}
	
	.nav-item-container {
		--gradient-start: #3b82f6;
		--gradient-end: #8b5cf6;
	}
	
	/* Colores modo claro */
	.desktop-nav-link:nth-child(1) { --solid-color: #0040df; }
	.desktop-nav-link:nth-child(2) { --solid-color: #4c6700; }
	.desktop-nav-link:nth-child(3) { --solid-color: #913a00; }
	.desktop-nav-link:nth-child(4) { --solid-color: #0040df; }
	.desktop-nav-link:nth-child(5) { --solid-color: #4c6700; }
	
	/* Colores modo oscuro - usando data-theme */
	[data-theme="dark"] .desktop-nav-link:nth-child(1) { --solid-color: #6695ff; }
	[data-theme="dark"] .desktop-nav-link:nth-child(2) { --solid-color: #b5d06e; }
	[data-theme="dark"] .desktop-nav-link:nth-child(3) { --solid-color: #ff8c61; }
	[data-theme="dark"] .desktop-nav-link:nth-child(4) { --solid-color: #6695ff; }
	[data-theme="dark"] .desktop-nav-link:nth-child(5) { --solid-color: #b5d06e; }
	
	[data-theme="dark"] .mobile-nav-link:nth-child(1) { --solid-color: #6695ff; }
	[data-theme="dark"] .mobile-nav-link:nth-child(2) { --solid-color: #b5d06e; }
	[data-theme="dark"] .mobile-nav-link:nth-child(3) { --solid-color: #ff8c61; }
	[data-theme="dark"] .mobile-nav-link:nth-child(4) { --solid-color: #6695ff; }
	[data-theme="dark"] .mobile-nav-link:nth-child(5) { --solid-color: #b5d06e; }
	.dark .mobile-nav-link:nth-child(5) { --solid-color: #b5d06e; }
</style>

<script>
	import { gsap } from 'gsap';

	// Configuración inicial para animaciones avanzadas
	const desktopNavLinks = document.querySelectorAll('.desktop-nav-link');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
	
	// Animación inicial del navbar con efecto de revelado
	gsap.set('.desktop-nav-link', {
		opacity: 0,
		y: -30,
		rotationX: -15,
		transformPerspective: 1000
	});

	// Timeline de revelado escalonado con efecto elástico
	const revealTimeline = gsap.timeline({ paused: true });
	
	revealTimeline
		.to('.desktop-nav-link', {
			opacity: 1,
			y: 0,
			rotationX: 0,
			duration: 1,
			stagger: 0.2,
			ease: "back.out(1.7)"
		});

	// Iniciar animación después de la carga
	setTimeout(() => {
		revealTimeline.play();
	}, 800);

	// Hover effects avanzados en desktop
	desktopNavLinks.forEach((link, index) => {
		const icon = link.querySelector('.material-symbols-outlined');
		const underline = link.querySelector('.h-0\\.5');
		const iconContainer = link.querySelector('.w-10');
		const textFill = link.querySelector('.nav-text-fill');
		const textBase = link.querySelector('.nav-text-base');
		
		link.addEventListener('mouseenter', () => {
			// Efecto 3D avanzado
			gsap.to(link, {
				scale: 1.02,
				y: -2,
				rotationZ: Math.random() * 2 - 1,
				duration: 0.4,
				ease: "power3.out"
			});
			
			// Mostrar texto fill con slide
			// Eliminado - efecto deshabilitado por UX
			
			// Ocultar texto base gradualmente
			// Eliminado - efecto deshabilitado por UX
			
			// Icono con efecto rebote
			gsap.to(iconContainer, {
				scale: 1.1,
				rotation: 6,
				duration: 0.4,
				ease: "back.out(1.7)"
			});
			
			// Subrayado animado
			gsap.to(underline, {
				width: '100%',
				duration: 0.5,
				ease: "power3.out"
			});
			
			// Crear partículas flotantes
			createParticles(link);
		});

		link.addEventListener('mouseleave', () => {
			// Restaurar estado 3D
			gsap.to(link, {
				scale: 1,
				y: 0,
				rotationZ: 0,
				duration: 0.4,
				ease: "power2.out"
			});
			
			// Ocultar texto fill
			// Eliminado - efecto deshabilitado por UX
			
			// Mostrar texto base nuevamente
			// Eliminado - efecto deshabilitado por UX
			
			// Icono retrocede
			gsap.to(iconContainer, {
				scale: 1,
				rotation: 0,
				duration: 0.4,
				ease: "power2.out"
			});
			
			// Subrayado retrocede
			gsap.to(underline, {
				width: '0%',
				duration: 0.3,
				ease: "power2.out"
			});
		});
	});

	// Función para crear partículas flotantes
	function createParticles(container) {
		for (let i = 0; i < 3; i++) {
			const particle = document.createElement('span');
			particle.className = 'absolute w-1 h-1 rounded-full pointer-events-none';
			particle.style.background = `linear-gradient(135deg, ${getComputedStyle(container).getPropertyValue('--gradient-start')}, ${getComputedStyle(container).getPropertyValue('--gradient-end')})`;
			
			container.appendChild(particle);
			
			// Animación de partícula
			gsap.fromTo(particle, {
				x: 0,
				y: 0,
				opacity: 1,
				scale: 0
			}, {
				x: Math.random() * 100 - 50,
				y: Math.random() * -50 - 20,
				opacity: 0,
				scale: 1,
				duration: 1.5,
				ease: "power2.out",
				onComplete: () => particle.remove()
			});
		}
	}

	// Menú móvil simplificado
	const mobileMenu = document.getElementById('mobile-menu');
	const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
	const mobileMenuClose = document.getElementById('mobile-menu-close');

	// Abrir menú
	mobileMenuToggle?.addEventListener('click', () => {
		if (mobileMenu) {
			mobileMenu.style.display = 'block';
		}
	});

	// Cerrar menú
	mobileMenuClose?.addEventListener('click', () => {
		if (mobileMenu) {
			mobileMenu.style.display = 'none';
		}
	});

	// Cerrar al hacer click fuera
	mobileMenu?.addEventListener('click', (e) => {
		if (e.target === mobileMenu) {
			mobileMenu.style.display = 'none';
		}
	});

	// Mobile theme toggle simplificado
	const mobileThemeBtn = document.getElementById('mobile-theme-btn');
	const themeIconDark = document.getElementById('theme-icon-dark');
	const themeIconLight = document.getElementById('theme-icon-light');
	const themeTextDark = document.getElementById('theme-text-dark');
	const themeTextLight = document.getElementById('theme-text-light');

	function updateMobileThemeSimple(theme: string) {
		if (theme === 'dark') {
			themeIconDark?.classList.add('hidden');
			themeIconLight?.classList.remove('hidden');
			themeTextDark?.classList.add('hidden');
			themeTextLight?.classList.remove('hidden');
		} else {
			themeIconDark?.classList.remove('hidden');
			themeIconLight?.classList.add('hidden');
			themeTextDark?.classList.remove('hidden');
			themeTextLight?.classList.add('hidden');
		}
	}

	// Initialize
	let currentMobileTheme = localStorage.getItem('theme') || 'light';
	updateMobileThemeSimple(currentMobileTheme);

	// Handle click
	mobileThemeBtn?.addEventListener('click', () => {
		const newTheme = currentMobileTheme === 'light' ? 'dark' : 'light';
		document.documentElement.classList.toggle('dark');
		localStorage.setItem('theme', newTheme);
		currentMobileTheme = newTheme;
		updateMobileThemeSimple(newTheme);
		document.dispatchEvent(new CustomEvent('darkmode:change', {
			detail: { enabled: newTheme === 'dark' },
			bubbles: true
		}));
	});

	// Listen for changes
	document.addEventListener('darkmode:change', (e: any) => {
		if (e.detail && typeof e.detail.enabled === 'boolean') {
			const theme = e.detail.enabled ? 'dark' : 'light';
			currentMobileTheme = theme;
			updateMobileThemeSimple(theme);
		}
	});

	// Cerrar con Escape
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && mobileMenu?.style.display === 'block') {
			mobileMenu.style.display = 'none';
		}
	});
</script>
