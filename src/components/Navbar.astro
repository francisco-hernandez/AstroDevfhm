      },
      en: {
        "nav.home": "Home", "nav.services": "Services", "nav.about": "About", "nav.projects": "Projects", "nav.faq": "FAQ", "nav.blog": "Blog", "nav.contact": "Contact",
        "hero.badge": "IDENTITY / 01", "hero.title": "Curating the <br /> Future <span class='text-outline-digital ml-2'>Digital</span>", "hero.desc": "High-impact UX/UI design with a disruptive soul.", "hero.cta": "Start Project", "hero.portfolio": "View Portfolio",
        "stack.badge": "Tech Stack", "stack.title": "<span class='text-on-background text-[1.15em] font-black'>Tech</span> <span style='background-color: rgb(184, 243, 0); padding: 0 10px;'>Experience</span>", "stack.desc": "We use the most powerful tools in the ecosystem.", "stack.cta": "View Completed Projects",
        "services.badge": "SERVICES / 02", "services.title": "Limitless <span class='bg-primary-container/20 px-2 italic'>Solutions</span>",
        "services.s1_title": "Enterprise Web Pages", "services.s1_desc": "Robust architecture for corporations seeking digital leadership and stability.",
        "services.s2_title": "Online Stores or Ecommerce", "services.s2_desc": "We convert visitors into loyal customers with optimized sales funnels.",
        "services.s3_title": "Professional Services", "services.s3_desc": "The perfect digital showcase for consultants and creatives demanding distinction.",
        "services.s4_title": "Landing Page", "services.s4_desc": "High-impact structures designed for campaigns and immediate results.",
        "services.s5_title": "SEO & SEM", "services.s5_desc": "Visibility strategies to attract qualified traffic and maximize conversions.",
        "services.s6_title": "Email Marketing", "services.s6_desc": "Automated campaigns designed to engage audiences and increase sales.",
        "about.badge": "ABOUT ME / 03", "about.title": "We don't make webs. <br /> We create <span style='background-color: rgb(184, 243, 0); padding: 0 10px;'>Experiences</span>.", "about.desc": "At devfhm.com, every pixel has a purpose.",
        "about.stat1_val": "+10", "about.stat1_label": "YEARS OF EXPERIENCE",
        "about.stat2_val": "99.9%", "about.stat2_label": "Guaranteed Uptime",
        "about.stat3_label": "Creativity driven by code.",
        "projects.title": "Projects with <span class='text-[#0a0f00] bg-[#C1FF00] px-4 py-1 italic rounded-lg'>Impact</span>",
        "projects.explore": "Explore Project", "projects.p1_desc": "Full redesign of the luxury shopping experience.",
        "faq.badge": "FAQ / 05", "faq.title": "Common <span class='text-[#0a0f00] bg-[#C1FF00] px-4 py-1 italic rounded-lg'>Questions</span>",
        "faq.desc": "We resolve your doubts so we can take the next step with full confidence.",
        "faq.q1": "How long does it take to develop a website?", "faq.a1": "Development time varies depending on the size and complexity of the project. For simple websites, the process can take between 2 and 4 weeks. Conversely, more complex projects, such as those including CRM integrations or custom developments, may require 6 to 12 weeks. Most importantly, we collaborate with you to establish a clear timeline from the start, ensuring you are informed at every stage of the process.",
        "faq.q2": "Do you offer support after the website is launched?", "faq.a2": "Yes, we offer post-launch support to ensure your website runs smoothly. Support packages include maintenance, updates, and technical support. We also offer custom plans based on your specific needs.",
        "faq.q3": "Will the website be responsive and mobile-friendly?", "faq.a3": "Absolutely. All our websites are designed to be fully responsive, meaning they will adapt and function perfectly on any device, whether it's a desktop, a tablet, or a mobile phone.",
        "faq.q4": "Can I update my website's content on my own?", "faq.a4": "Yes, we provide websites with content management systems (CMS) like WordPress, which allow you to easily edit and update your site's content without needing technical knowledge. We provide training so you can manage your site effectively.",
        "faq.q5": "How do you handle website security?", "faq.a5": "On our websites, we prioritize security by implementing current best practices and technologies. We use SSL certificates to encrypt information, ensuring that data between the user and the server is protected. Additionally, we implement firewalls, robust authentication, and monitoring tools to prevent unauthorized access and malicious attacks. We also keep our systems and plugins up to date and apply regular backup measures to guarantee data integrity. Your website will be protected against common online threats.",
        "blog_home.badge": "BLOG / 06", "blog_home.title": "Notebook <span class='text-[#0a0f00] bg-[#C1FF00] px-4 py-1 italic rounded-lg'>Entries</span>", "blog_home.view_all": "View all entries", "blog_home.read_more": "Read more",
        "contact.badge": "CONTACT / 07", "contact.title": "Ready to <br /> <span class='text-[#0a0f00] bg-[#C1FF00] px-4 py-1 italic rounded-lg'>innovate?</span>",
        "contact.desc": "Tell us your vision. We are ready to transform it into an impeccable digital reality.",
        "contact.label_name": "Full Name(*)", "contact.placeholder_name": "e.g. John Doe",
        "contact.label_email": "Corporate Email", "contact.placeholder_email": "your@company.com",
        "contact.label_project": "Project Type", "contact.placeholder_project": "e.g. Ecommerce",
        "contact.label_message": "Message(*)", "contact.placeholder_message": "Tell us about your project...",
        "contact.submit": "Send Message",
        "blog.badge": "BLOG / 01", "blog.title": "Notebook <span style='background-color: rgb(184, 243, 0)'>Entries</span>", "blog.desc": "Exploring the intersection of design and technology.", "blog.featured_badge": "Featured Post", "blog.featured_cta": "Read Manifesto", "blog.read_more": "Read more",
        "article.title": "Curating the <br /> <span class='text-primary italic'>Future</span> <span class='text-stroke text-primary'>Digital</span>", "article.intro": "The intersection between editorial aesthetics and software engineering...", "article.p1": "We live in an era where the user inhabits experiences.", "article.p2": "By eliminating traditional grid lines...", "article.h2": "The Engineering of Controlled Chaos", "article.p3": "The code above illustrates our approach...", "article.h3": "The Legacy of Aesthetics", "article.p4": "Finally, we must consider the emotional impact...",
        "article.related_title": "Related Articles", "article.view_all": "View all",
        "footer.github": "Github", "footer.terms": "Terms & Conditions", "footer.privacy": "Privacy Policy", "footer.social": "Socials", "footer.copyright": "© 2026 DEVFHM. All rights reserved.", "footer.designed": "Designed by and for the web"
      }
    };

    const langToggle = document.getElementById('lang-toggle');
    // If on an article page, use the article's own lang as the current language
    const articleLang = document.body.getAttribute('data-article-lang');
    let currentLang = articleLang || localStorage.getItem('lang') || 'es';

    function updateLanguage() {
      document.querySelectorAll('[data-key]').forEach(el => {
        const key = el.getAttribute('data-key');
        if (translations[currentLang] && translations[currentLang][key]) {
          const content = translations[currentLang][key];
          if (content.includes('<br') || content.includes('<span')) {
            el.innerHTML = content;
          } else {
            if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
              el.setAttribute('placeholder', content);
            } else {
              const icon = el.querySelector('.material-symbols-outlined');
              el.innerText = content;
              if (icon) el.appendChild(icon);
            }
          }
        }
      });

      // Show/Hide elements based on language
      document.querySelectorAll('[data-lang]').forEach(el => {
        const elLang = el.getAttribute('data-lang');
        if (elLang === currentLang) {
          el.style.removeProperty('display');
        } else {
          el.style.setProperty('display', 'none', 'important');
        }
      });

      if (langToggle) langToggle.innerText = currentLang === 'es' ? 'EN' : 'ES';
      document.documentElement.lang = currentLang;
      localStorage.setItem('lang', currentLang);
    }

    if (langToggle) {
      langToggle.addEventListener('click', () => {
        // Check if we're on an article page with a translation available
        const translationSlug = document.body.getAttribute('data-translation-slug');

        if (articleLang && translationSlug) {
          // We're on a translated article — navigate to the paired article
          window.location.href = `/blog/${translationSlug}`;
          return;
        }

        if (articleLang && !translationSlug) {
          // Article exists but has no translation — just toggle i18n texts on the page
          currentLang = currentLang === 'es' ? 'en' : 'es';
          updateLanguage();
          return;
        }

        // Default: we're on the main site, just toggle i18n
        currentLang = currentLang === 'es' ? 'en' : 'es';
        updateLanguage();
      });
    }

    // Initial language update
    updateLanguage();

    // Theme Logic
    const themeToggle = document.getElementById('theme-toggle');
    let currentTheme = localStorage.getItem('theme') || 'light';

    function updateTheme() {
      if (currentTheme === 'dark') {
        document.documentElement.classList.add('dark');
        if (themeToggle) themeToggle.innerText = 'light_mode';
      } else {
        document.documentElement.classList.remove('dark');
        if (themeToggle) themeToggle.innerText = 'dark_mode';
      }
      localStorage.setItem('theme', currentTheme);
    }

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        currentTheme = currentTheme === 'light' ? 'dark' : 'light';
        updateTheme();
      });
    }

    updateTheme();

    // Mobile Menu Logic with GSAP
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    let isMenuOpen = false;

    if (menuBtn && mobileMenu && typeof gsap !== 'undefined') {
      const menuTl = gsap.timeline({ paused: true });

      menuTl.to(mobileMenu, {
        display: 'flex',
        opacity: 1,
        duration: 0.4,
        ease: 'power3.out'
      }).from('.mobile-link', {
        y: 20,
        opacity: 0,
        stagger: 0.1,
        duration: 0.4,
        ease: 'power2.out'
      }, "-=0.2");

      menuBtn.addEventListener('click', () => {
        if (!isMenuOpen) {
          menuBtn.innerText = 'close';
          menuTl.play();
        } else {
          menuBtn.innerText = 'menu';
          menuTl.reverse();
        }
        isMenuOpen = !isMenuOpen;
      });

      // Close menu on link click
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          menuBtn.innerText = 'menu';
          menuTl.reverse();
          isMenuOpen = false;
        });
      });
    }
  });
</script>
